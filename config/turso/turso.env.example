# Turso Database Configuration
# Copy this file to turso.env and fill in your values

# Turso Database URL (Get from Turso dashboard)
TURSO_URL=libsql://your-database-url.turso.io

# Turso Authentication Token (Generate from Turso CLI: turso auth tokens create)
TURSO_AUTH_TOKEN=your-auth-token-here

# Turso Database Name
TURSO_DATABASE_NAME=surfdesk

# Enable/disable Turso (set to "true" to use Turso, "false" to use SQLite)
ENABLE_TURSO=false

# Optional: Custom SQLite path (used when ENABLE_TURSO=false)
SQLITE_PATH=./data/surfdesk.db
```

